<com.infomaniak.mail.views.BottomSheetScaffoldingView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.main.thread.actions.AskEuriaBottomSheetDialog">

    <com.infomaniak.mail.ui.main.thread.actions.ActionItemView
        android:id="@+id/summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:icon="@drawable/ic_paragraph_shorten"
        app:title="@string/actionSummarize"
        app:visibleDivider="false" />

    <com.infomaniak.mail.ui.main.thread.actions.ActionItemView
        android:id="@+id/reply"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:icon="@drawable/ic_reply_euria"
        app:title="@string/actionReply" />

    <com.infomaniak.mail.ui.main.thread.actions.ActionItemView
        android:id="@+id/translate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:icon="@drawable/ic_translate"
        app:title="@string/buttonTranslate" />

</com.infomaniak.mail.views.BottomSheetScaffoldingView>


