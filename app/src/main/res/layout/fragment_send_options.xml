<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/newMessageBackgroundColor"
    android:fitsSystemWindows="true"
    tools:context=".ui.newMessage.sendOptions.DraftSendOptionsFragment">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:background="@color/toolbarLoweredColor"
        android:touchscreenBlocksFocus="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:navigationContentDescription="@string/contentDescriptionButtonBack"
        app:navigationIcon="@drawable/ic_chevron_left"
        app:navigationIconTint="@color/iconColor"
        app:title="@string/sendOptions"
        app:titleCentered="true" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/saveButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@drawable/divider"
            android:dividerPadding="@dimen/marginStandardMedium"
            android:orientation="vertical"
            android:paddingBottom="@dimen/marginStandardMedium"
            android:showDividers="middle">

            <com.infomaniak.mail.ui.main.settings.ItemSettingView
                android:id="@+id/reminderIfNoAnswer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_alarm_clock"
                app:iconColor="?attr/colorPrimary"
                app:itemAction="toggle"
                app:subtitle="@string/explanationActionCallIfNoResponse"
                app:title="@string/actionCallIfNoResponse" />

            <com.infomaniak.mail.ui.main.settings.SettingRadioGroupView
                android:id="@+id/optionsDelays"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                tools:visibility="visible">

                <com.infomaniak.mail.ui.main.settings.SettingRadioButtonView
                    android:id="@+id/hours24"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:value="24"
                    tools:text="24 hours" />

                <com.infomaniak.mail.ui.main.settings.SettingRadioButtonView
                    android:id="@+id/days3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:value="72"
                    tools:text="3 days" />

                <com.infomaniak.mail.ui.main.settings.SettingRadioButtonView
                    android:id="@+id/days7"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:value="168"
                    tools:text="7 days" />

            </com.infomaniak.mail.ui.main.settings.SettingRadioGroupView>

            <com.infomaniak.mail.ui.main.settings.ItemSettingView
                android:id="@+id/customDelayReminder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:itemAction="chevron"
                app:title="@string/buttonCustomReminder"
                tools:visibility="visible" />

            <com.infomaniak.mail.ui.main.settings.ItemSettingView
                android:id="@+id/scheduleSending"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_schedule_send"
                app:iconColor="?attr/colorPrimary"
                app:itemAction="toggle"
                app:title="@string/scheduleSendingTitle" />

            <com.infomaniak.mail.ui.main.settings.SettingRadioGroupView
                android:id="@+id/scheduleOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                tools:visibility="visible">

                <com.infomaniak.mail.ui.main.settings.SettingRadioButtonView
                    android:id="@+id/lastScheduleOption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    app:text="@string/lastSelectedSchedule"
                    tools:visibility="visible" />

            </com.infomaniak.mail.ui.main.settings.SettingRadioGroupView>

            <com.infomaniak.mail.ui.main.settings.ItemSettingView
                android:id="@+id/customScheduleOption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:itemAction="chevron"
                app:title="@string/buttonCustomSchedule"
                tools:visibility="visible" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/saveButton"
        style="@style/TextButtonPrimary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/marginStandardMedium"
        android:layout_marginBottom="@dimen/marginStandardMedium"
        android:text="@string/buttonSave"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
